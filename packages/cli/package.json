{
  "name": "bastion-scan",
  "version": "0.1.1",
  "description": "Privacy-first security checker for web projects. 15 checks, zero data uploaded, actionable fixes.",
  "type": "module",
  "bin": {
    "bastion": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "security",
    "scanner",
    "cli",
    "owasp",
    "privacy",
    "devtools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/absastreon/bastion.git"
  },
  "homepage": "https://bastion.wiki",
  "author": "ABS Astreon",
  "license": "MIT",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "bastion-shared": "^0.1.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0"
  }
}
